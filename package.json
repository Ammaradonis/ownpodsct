{
  "name": "archive-signal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "preview": "astro preview",
    "lint": "eslint . --ext .js,.mjs,.ts,.astro",
    "format": "prettier --write .",
    "check": "astro check",
    "validate": "node scripts/validate-content.mjs",
    "rss": "node scripts/build-rss.mjs",
    "sitemap": "node scripts/build-sitemap.mjs",
    "build": "node scripts/validate-content.mjs && astro build && node scripts/build-rss.mjs && node scripts/build-sitemap.mjs && pagefind --site dist",
    "test": "vitest run",
    "test:rss": "vitest run tests/rss.test.mjs",
    "test:e2e": "playwright test",
    "new:episode": "node scripts/new-episode.mjs",
    "verify:archive": "node scripts/verify-archive-all.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.json": [
      "prettier --write"
    ],
    "*.{js,mjs,ts,astro}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "astro": "^6.1.9",
    "fast-xml-parser": "^4.5.0",
    "marked": "^15.0.4",
    "xmlbuilder2": "^3.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jridgewell/sourcemap-codec": "^1.5.5",
    "@playwright/test": "^1.53.0",
    "@typescript-eslint/parser": "^8.31.0",
    "astro-eslint-parser": "^1.1.0",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "minimatch": "^10.2.5",
    "pagefind": "^1.3.0",
    "postcss": "^8.4.49",
    "postcss-preset-env": "^10.0.8",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.1"
  }
}
