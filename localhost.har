 <strong data-theme-label data-astro-cid-x3pjskd3 data-astro-source-file=\"C:/Users/FingerWeg/CascadeProjects/podcast/src/components/ThemeToggle.astro\" data-astro-source-loc=\"3:28\">Auto</strong> </button> <script>\n  const button = document.querySelector('[data-theme-toggle]');\n  const label = document.querySelector('[data-theme-label]');\n\n  if (button && label) {\n    const readTheme = () =>\n      document.documentElement.dataset.themePreference ||\n      document.documentElement.dataset.theme ||\n      'auto';\n    const applyLabel = () => {\n      const value = readTheme();\n      label.textContent = value.charAt(0).toUpperCase() + value.slice(1);\n      button.setAttribute('aria-pressed', value !== 'auto' ? 'true' : 'false');\n    };\n\n    button.addEventListener('click', () => {\n      const current = readTheme();\n      const next = current === 'light' ? 'dark' : current === 'dark' ? 'auto' : 'light';\n\n      if (next === 'auto') {\n        localStorage.removeItem('theme');\n        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;\n        document.documentElement.dataset.theme = prefersDark ? 'dark' : 'light';\n        document.documentElement.dataset.themePreference = 'auto';\n      } else {\n        localStorage.setItem('theme', next);\n        document.documentElement.dataset.theme = next;\n        document.documentElement.dataset.themePreference = next;\n      }\n\n      applyLabel();\n    });\n\n    applyLabel();\n  }\n</script> </div> </header> <main data-astro-source-file=\"C:/Users/FingerWeg/CascadeProjects/podcast/src/layouts/BaseLayout.astro\" data-astro-source-loc=\"63:11\">  <article class=\"shell episode-page\" data-astro-cid-xfsepetq data-astro-source-file=\"C:/Users/FingerWeg/CascadeProjects/podcast/src/layouts/EpisodeLayout.astro\" data-astro-source-loc=\"33:39\"> <header class=\"episode-header reveal\" data-astro-cid-xfsepetq data-astro-source-file=\"C:/Users/FingerWeg/CascadeProjects/podcast/src/layouts