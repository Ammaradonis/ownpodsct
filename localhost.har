            "mimeType": "text/javascript",
            "text": "import { createHotContext as __vite__createHotContext } from \"/@vite/client\";import.meta.hot = __vite__createHotContext(\"/src/styles/global.css\");import { updateStyle as __vite__updateStyle, removeStyle as __vite__removeStyle } from \"/@vite/client\"\nconst __vite__id = \"C:/Users/FingerWeg/CascadeProjects/podcast/src/styles/global.css\"\nconst __vite__css = \"body {\\n  min-height: 100vh;\\n  font-family: var(--font-body);\\n  line-height: 1.6;\\n  color: var(--color-text);\\n  background:\\n    radial-gradient(circle at top left, rgba(13, 92, 99, 0.14), transparent 30%),\\n    radial-gradient(circle at top right, rgba(255, 127, 81, 0.1), transparent 34%),\\n    linear-gradient(180deg, var(--color-page), color-mix(in srgb, var(--color-page) 82%, #d9cab6));\\n}\\n\\na {\\n  color: inherit;\\n  -webkit-text-decoration: none;\\n  text-decoration: none;\\n}\\n\\na:hover {\\n  color: var(--color-accent);\\n}\\n\\nbutton,\\na,\\nsummary {\\n  transition:\\n    transform 180ms ease, color 180ms ease, border-color 180ms ease, background 180ms ease;\\n}\\n\\nbutton:hover,\\na:hover,\\nsummary:hover {\\n  transform: translateY(-1px);\\n}\\n\\n:focus-visible {\\n  outline: 3px solid var(--color-focus);\\n  outline-offset: 3px;\\n}\\n\\nmain {\\n  padding-top: 2rem;\\n}\\n\\n.shell {\\n  width: var(--shell);\\n  margin-left: auto;\\n  margin-right: auto;\\n}\\n\\n.page-hero {\\n  padding-top: 3rem;\\n  padding-bottom: 2rem;\\n}\\n\\n.eyebrow {\\n  display: inline-flex;\\n  align-items: center;\\n  gap: 0.5rem;\\n  color: var(--color-muted);\\n  text-transform: uppercase;\\n  letter-spacing: 0.16em;\\n  font-size: 0.78rem;\\n}\\n\\n.lede {\\n  max-width: 60ch;\\n  font-size: max(1.05rem, min(2vw, 1.25rem));\\n  color: var(--color-muted);\\n}\\n\\nh1,\\nh2,\\nh3 {\\n  font-family: var(--font-display);\\n  line-height: 1.05;\\n  letter-spacing: -0.02em;\\n}\\n\\nh1 {\\n  font-size: max(2.6rem, min(6vw, 5.4rem));\\n}\\n\\nh2 {\\n  font-size: max(2rem, min(3vw, 3.1rem));\\n}\\n\\n.card {\\n  padding: 1.3rem;\\n  border-radius: var(--radius-card);\\n  background: color-mix(in srgb, var(--color-surface) 90%, white 10%);\\n  border: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);\\n  box-shadow: var(--shadow-card);\\n}\\n\\n.section {\\n  padding-top: 2rem;\\n  padding-bottom: 2rem;\\n}\\n\\n.grid {\\n  display: grid;\\n  grid-gap: 1.25rem;\\n  gap: 1.25rem;\\n}\\n\\n.grid--shows {\\n  grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));\\n}\\n\\n.grid--episodes {\\n  grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));\\n}\\n\\n.prose {\\n  display: grid;\\n  grid-gap: 1rem;\\n  gap: 1rem;\\n}\\n\\n.prose ul,\\n.prose ol {\\n  padding-left: 1.25rem;\\n}\\n\\n.reveal {\\n  animation: rise-in 0.7s ease both;\\n}\\n\\n@keyframes rise-in {\\n  from {\\n    opacity: 0;\\n    transform: translateY(20px);\\n  }\\n  to {\\n    opacity: 1;\\n    transform: translateY(0);\\n  }\\n}\\n\\n@media (prefers-reduced-motion: reduce) {\\n  *,\\n  *::before,\\n  *::after {\\n    animation-duration: 0.001ms !important;\\n    animation-iteration-count: 1 !important;\\n    scroll-behavior: auto !important;\\n    transition-duration: 0.001ms !important;\\n  }\\n}\\n\"\n__vite__updateStyle(__vite__id, __vite__css)\nimport.meta.hot.accept()\nimport.meta.hot.prune(() => __vite__removeStyle(__vite__id))"
