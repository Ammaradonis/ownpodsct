---
import { getCategories } from '../lib/getCategories';
import { getPublishedEpisodes } from '../lib/getEpisodes';
import { getTagCounts } from '../lib/tags';
import { siteConfig } from '../lib/site';
import TagCloud from './TagCloud.astro';

const categories = await getCategories();
const episodes = await getPublishedEpisodes();
const tagCloud = getTagCounts([
  ...categories.flatMap((category) => category.data.tags),
  ...episodes.flatMap((episode) => episode.data.tags),
]).slice(0, 14);
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <section>
      <h2>Archive Signal</h2>
      <p>{siteConfig.description}</p>
      <a class="footer-link" href="/feeds/main.xml">Subscribe to the network feed</a>
    </section>

    <section>
      <h2>Shows</h2>
      <ul class="footer-list">
        {categories.map((category) => (
          <li>
            <a href={`/shows/${category.data.slug}/`}>{category.data.title}</a>
          </li>
        ))}
      </ul>
    </section>

    <section>
      <h2>Popular tags</h2>
      <TagCloud tags={tagCloud} />
    </section>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 5rem;
    padding: 4rem 0 5rem;
    border-top: 1px solid color-mix(in srgb, var(--color-border) 70%, transparent);
    background:
      radial-gradient(circle at top left, rgb(255 127 81 / 0.14), transparent 34%),
      linear-gradient(180deg, transparent, color-mix(in srgb, var(--color-page) 92%, black 8%));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
  }

  .footer-list {
    padding: 0;
    margin: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }

  .footer-link {
    font-weight: 600;
  }

  h2 {
    margin-bottom: 0.8rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
