---
import type { CollectionEntry } from 'astro:content';

import ChapterList from './ChapterList.astro';
import { formatShortDuration } from '../lib/formatDuration';

interface Props {
  episode: CollectionEntry<'episodes'>;
}

const { episode } = Astro.props;
const audioTracks = episode.data.audio_tracks ?? [];
const tracks =
  audioTracks.length > 0
    ? audioTracks
    : [
        {
          title: episode.data.title,
          url: episode.data.media.primary_url,
          mime_type: episode.data.media.mime_type,
          duration_seconds: episode.data.duration_seconds,
          file_size_bytes: episode.data.media.file_size_bytes,
        },
      ];
---

<section
  class="player-shell card"
  data-player
  data-episode-id={episode.data.id}
  data-episode-slug={episode.data.slug}
  data-mirror-url={episode.data.media.mirror_url ?? ''}
  data-title={episode.data.title}
  data-duration={tracks[0]?.duration_seconds ?? episode.data.duration_seconds}
  data-repeat-current-track={episode.data.slug === 'arabic-quranic-recordings' ? 'true' : 'false'}
>
  <div class="player-toolbar">
    <button type="button" data-skip="-15" aria-label="Skip back 15 seconds">-15s</button>
    <button type="button" data-skip="30" aria-label="Skip forward 30 seconds">+30s</button>
    <label>
      Speed
      <select data-speed>
        <option value="0.75">0.75x</option>
        <option value="1" selected>1x</option>
        <option value="1.25">1.25x</option>
        <option value="1.5">1.5x</option>
        <option value="2">2x</option>
      </select>
    </label>
    <button type="button" data-copy-timestamp>Copy timestamp link</button>
  </div>
  <audio
    controls
    preload="metadata"
    src={tracks[0]?.url ?? episode.data.media.primary_url}
    data-media
    data-duration={tracks[0]?.duration_seconds ?? episode.data.duration_seconds}
  >
    Your browser does not support audio. <a href={tracks[0]?.url ?? episode.data.media.primary_url}>Download MP3</a>.
  </audio>
  {tracks.length > 1 && (
    <section class="track-list" aria-label="Episode tracks">
      <h2>Tracks</h2>
      <ul>
        {tracks.map((track, index) => (
          <li>
            <div class="track-row">
              <button
                type="button"
                data-track-button
                data-track-index={index}
                data-track-url={track.url}
                data-track-duration={track.duration_seconds}
                class:list={{ 'is-active': index === 0 }}
              >
                <strong>{track.title}</strong>
                <span>{formatShortDuration(track.duration_seconds)}</span>
              </button>
              <button
                type="button"
                class="track-repeat-button"
                data-repeat-track-button
                data-track-index={index}
                aria-label={`Repeat ${track.title} at the current playback speed`}
              >
                Repeat
              </button>
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}
  <ChapterList chapters={episode.data.chapters} />
</section>

<script type="module" src="/scripts/player.js"></script>

<style>
  .player-shell {
    display: grid;
    gap: 1.2rem;
  }

  .player-toolbar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
  }

  .player-toolbar button,
  .player-toolbar select {
    font: inherit;
  }

  .player-toolbar button,
  .player-toolbar label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.95rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--color-border) 75%, transparent);
    background: color-mix(in srgb, var(--color-surface) 88%, white 12%);
    color: var(--color-text);
  }

  audio {
    width: 100%;
  }

  .track-list {
    display: grid;
    gap: 0.8rem;
  }

  .track-list ul {
    display: grid;
    gap: 0.8rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .track-list button {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.95rem 1rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-border) 75%, transparent);
    background: color-mix(in srgb, var(--color-surface) 88%, white 12%);
    color: var(--color-text);
    font: inherit;
    cursor: pointer;
    text-align: left;
  }

  .track-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.75rem;
    align-items: stretch;
  }

  .track-list button.is-active {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 12%, var(--color-surface) 88%);
  }

  .track-repeat-button {
    display: none;
    width: auto;
    white-space: nowrap;
    justify-content: center;
  }

  .track-repeat-button.is-visible {
    display: inline-flex;
  }

  .track-repeat-button.is-enabled {
    border-color: transparent;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-soft));
    color: #fff9f2;
  }

  .track-list span {
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 720px) {
    .track-row {
      grid-template-columns: 1fr;
    }

    .track-repeat-button {
      width: 100%;
    }
  }
</style>
