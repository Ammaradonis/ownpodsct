---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShowCard from '../../components/ShowCard.astro';
import { getCategories } from '../../lib/getCategories';
import { getPublishedEpisodes } from '../../lib/getEpisodes';

const categories = await getCategories();
const episodes = await getPublishedEpisodes();
const counts = new Map(
  categories.map((category) => [
    category.data.id,
    episodes.filter((episode) => episode.data.category_id === category.data.id).length,
  ]),
);
---

<BaseLayout
  title="Shows | Archive Signal"
  description="Browse every show in the Archive Signal network."
  pathname="/shows/"
>
  <section class="shell page-hero reveal">
    <p class="eyebrow">Shows</p>
    <h1>Every series, one index.</h1>
    <p class="lede">
      Each show gets its own pages, tags, and feed while still contributing to a combined network
      stream.
    </p>
  </section>

  <section class="shell section">
    <div class="grid grid--shows">
      {categories.map((show) => (
        <ShowCard show={show} episodeCount={counts.get(show.data.id) ?? 0} />
      ))}
    </div>
  </section>
</BaseLayout>
